    </violation>
    <violation name="Illegal meta character in header" id="VIOL_HEADER_METACHAR">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Mandatory HTTP header is missing" id="VIOL_MANDATORY_HEADER">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Hostname mismatch" id="VIOL_HOST_HEADER_MISMATCH">
      <alarm>true</alarm>
      <block>true</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <!-- ── Parameter ─────────────────────────────────────────────────────── -->
    <violation name="Mandatory parameter is missing" id="VIOL_MANDATORY_PARAMETER">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Parameter array size exceeded" id="VIOL_PARAMETER_ARRAY_SIZE">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Parameter data type failed" id="VIOL_PARAMETER_DATA_TYPE">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Parameter value supposed to be empty" id="VIOL_PARAMETER_EMPTY_VALUE">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Parameter found in unexpected location" id="VIOL_PARAMETER_LOCATION">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Illegal meta character in parameter" id="VIOL_PARAMETER_METACHAR">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Null in multipart parameter value" id="VIOL_PARAMETER_MULTIPART_NULL_VALUE">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>

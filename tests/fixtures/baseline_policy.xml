    <violation name="Illegal meta character in parameter name" id="VIOL_PARAMETER_NAME_METACHAR">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Parameter numeric value out of range" id="VIOL_PARAMETER_NUMERIC_VALUE">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Repeated parameter name" id="VIOL_PARAMETER_REPEATED">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Parameter static value mismatch" id="VIOL_PARAMETER_STATIC_VALUE">
      <alarm>true</alarm>
      <block>false</block>

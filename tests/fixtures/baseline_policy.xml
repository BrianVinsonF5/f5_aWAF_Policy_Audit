<?xml version="1.0" encoding="UTF-8"?>
<policy>
  <name>baseline_policy</name>
  <full-path>/Common/baseline_policy</full-path>
  <description>Corporate baseline WAF policy</description>
  <created-at>2025-01-01T00:00:00Z</created-at>
  <updated-at>2025-06-01T00:00:00Z</updated-at>

  <general>
    <enforcement-mode>blocking</enforcement-mode>
    <signature-staging>false</signature-staging>
    <placeholder-signatures>false</placeholder-signatures>
    <response-logging>none</response-logging>
    <trust-xff>false</trust-xff>
    <mask-credit-card-numbers>true</mask-credit-card-numbers>
    <enforcement-readiness-period>7</enforcement-readiness-period>
    <allowed-response-code>200</allowed-response-code>
    <allowed-response-code>301</allowed-response-code>
    <allowed-response-code>302</allowed-response-code>
    <allowed-response-code>404</allowed-response-code>
  </general>

  <!--
    Newer <blocking> section format used by some AWAF export versions.
    Violations are identified by machine-readable 'id' attributes.
    Baseline reflects a strict enforcement posture (blocking mode).
  -->
  <blocking>
    <enforcement_mode>blocking</enforcement_mode>
    <passive_mode>disabled</passive_mode>
    <!-- ── Evasion / protocol-level ─────────────────────────────────────── -->
    <violation name="Evasion technique detected" id="EVASION_DETECTED">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="HTTP protocol compliance failed" id="VIOL_HTTP_PROTOCOL">
      <alarm>true</alarm>
      <block>true</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Illegal HTTP status in response" id="VIOL_HTTP_RESPONSE_STATUS">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <!-- ── Login / session flow ─────────────────────────────────────────── -->
    <violation name="Login URL bypassed" id="ILLEGAL_INGRESS_OBJECT">
      <alarm>false</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Login URL expired" id="PARSER_EXPIRED_INGRESS_OBJECT">
      <alarm>false</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Session awareness" id="VIOL_SESSION_AWARENESS">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="CSRF attack detected" id="VIOL_CSRF">
      <alarm>true</alarm>
      <block>true</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <!-- ── Signatures / attacks ─────────────────────────────────────────── -->
    <violation name="Attack signature detected" id="VIOL_ATTACK_SIGNATURE">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Threat campaign detected" id="VIOL_THREAT_CAMPAIGN">
      <alarm>true</alarm>
      <block>true</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Cross-site scripting (XSS)" id="VIOL_CROSS_SITE_SCRIPTING">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Brute force attack" id="VIOL_BRUTE_FORCE">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <!-- ── Data Guard / response scrubbing ──────────────────────────────── -->
    <violation name="Data Guard: Information leakage detected" id="RESPONSE_SCRUBBING">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <!-- ── File / virus ──────────────────────────────────────────────────── -->
    <violation name="Virus detected" id="VIRUS_DETECTED">
      <alarm>true</alarm>
      <block>true</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Illegal file type" id="VIOL_FILETYPE">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Uploaded file detected" id="VIOL_FILE_UPLOAD">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Uploaded file detected in body" id="VIOL_FILE_UPLOAD_IN_BODY">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <!-- ── URL / method ──────────────────────────────────────────────────── -->
    <violation name="Illegal URL" id="VIOL_URL">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Illegal method" id="VIOL_METHOD">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>

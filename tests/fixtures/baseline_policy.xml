    <violation name="URL length exceeded" id="VIOL_URL_LENGTH">
      <alarm>true</alarm>
      <block>true</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Illegal meta character in URL" id="VIOL_URL_METACHAR">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Illegal content-type header in request" id="VIOL_URL_CONTENT_TYPE">
      <alarm>true</alarm>
      <block>true</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Illegal geo-location" id="VIOL_GEOLOCATION">
      <alarm>false</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <!-- ── Cookie / header ───────────────────────────────────────────────── -->
    <violation name="Modified ASM cookie" id="VIOL_ASM_COOKIE_MODIFIED">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="ASM cookie hijacking" id="VIOL_ASM_COOKIE_HIJACKING">
      <alarm>true</alarm>
      <block>true</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Modified domain cookie(s)" id="VIOL_COOKIE_MODIFIED">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Expired timestamp" id="VIOL_COOKIE_EXPIRED">
      <alarm>false</alarm>
      <block>false</block>

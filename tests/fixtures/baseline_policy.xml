    </violation>
    <violation name="Parameter value length exceeded" id="VIOL_PARAMETER_VALUE_LENGTH">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Illegal meta character in value" id="VIOL_PARAMETER_VALUE_METACHAR">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <!-- ── Request sizing ────────────────────────────────────────────────── -->
    <violation name="Request length exceeds defined buffer size" id="REQUEST_TOO_LONG">
      <alarm>true</alarm>
      <block>true</block>
      <learn>true</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>

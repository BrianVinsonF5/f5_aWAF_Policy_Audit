      <learn>false</learn>
      <policy_builder_tracking>enabled</policy_builder_tracking>
    </violation>
    <violation name="Header value too long" id="VIOL_HEADER_LENGTH">
      <alarm>true</alarm>
      <block>false</block>
      <learn>false</learn>

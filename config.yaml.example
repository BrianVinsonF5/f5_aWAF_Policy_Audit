bigip:
  host: "192.168.1.245"
  username: "admin"
  # password: NOT supported here — use the BIGIP_PASS environment variable
  #            or the interactive prompt to avoid plaintext credentials on disk.
  verify_ssl: true           # Set to false only for self-signed certs (dev/lab)
  login_provider: "tmos"     # Change for RADIUS/LDAP/AD auth providers

audit:
  baseline_policy: "./baseline/corporate_baseline.xml"
  output_dir: "./output"
  report_format: "both"       # html, markdown, both
  export_format: "xml"
  concurrent_exports: 3       # 1–20
  partitions: []              # empty = all partitions

gitlab:
  repo_url: "https://gitlab.example.com/netsec/policy-state.git"
  local_dir: "./policy_state_repo"
  branch: "main"
  auto_push: false            # true = commit + push after each run
  update_source_truth: false  # true = replace source_of_truth files with latest exports
